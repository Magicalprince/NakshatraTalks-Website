# API Configuration
NEXT_PUBLIC_API_URL=https://api.nakshatratalks.com
NEXT_PUBLIC_APP_URL=https://nakshatratalks.com

# Mock Data (set to true for local dev without backend)
NEXT_PUBLIC_USE_MOCK_DATA=false

# Supabase Self-Hosted (used for Realtime Broadcasts only)
# These point to the self-hosted Supabase instance on the same VPS as the backend.
# Get the URL and anon key from the Supabase self-hosted .env on the VPS
# (typically found at /home/ubuntu/supabase/.env or ask your team lead).
# NOTE: Do NOT use the old Supabase Cloud URL (vckkbwvjczptjwixxvwi.supabase.co).
NEXT_PUBLIC_SUPABASE_URL=https://supabase.nakshatratalks.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_self_hosted_supabase_anon_key

# Razorpay (shared with mobile app)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
